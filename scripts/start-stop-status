#!/bin/sh
# Runs as the package user. We cannot write /etc/crontab, so scheduling
# is handled by a long-running Python daemon (bin/scheduler.py).

PKG_DIR="/var/packages/iCloudPhotoSync"
TARGET_DIR="$PKG_DIR/target"
VAR_DIR="$PKG_DIR/var"
SCHEDULER="$TARGET_DIR/bin/scheduler.py"
PID_FILE="$VAR_DIR/scheduler.pid"
LOG_DIR="$VAR_DIR/logs"
LOG_FILE="$LOG_DIR/scheduler.log"
STARTUP_ERR="$LOG_DIR/startup-error.log"

# Python interpreter detection. DSM 7.2+ has /usr/bin/python3. Older DSMs
# or some j-series builds use the Python3 package from Package Center,
# which installs under /var/packages/py3k/ or /var/packages/python3/.
# Without this fallback the daemon dies silently before any log is written
# and DSM shows the package as "stopped" immediately after start.
find_python() {
    for c in \
        /usr/bin/python3 \
        /usr/bin/python3.8 \
        /usr/bin/python3.9 \
        /usr/bin/python3.10 \
        /usr/bin/python3.11 \
        /usr/local/bin/python3 \
        /var/packages/py3k/target/usr/bin/python3 \
        /var/packages/python3/target/usr/bin/python3
    do
        [ -x "$c" ] && { echo "$c"; return 0; }
    done
    command -v python3 2>/dev/null && return 0
    return 1
}

mkdir -p "$LOG_DIR" 2>/dev/null || true

is_running() {
    [ -f "$PID_FILE" ] || return 1
    PID=$(cat "$PID_FILE" 2>/dev/null)
    [ -n "$PID" ] || return 1
    kill -0 "$PID" 2>/dev/null
}

log_startup_err() {
    # Capture why start failed in a location the user (and we) can point
    # at when debugging "package keeps stopping" reports. Timestamped so
    # repeated start attempts build up a history.
    {
        echo "==== $(date '+%Y-%m-%d %H:%M:%S') start-stop-status failure ===="
        echo "$@"
    } >> "$STARTUP_ERR" 2>/dev/null
}

case $1 in
    start)
        if is_running; then
            exit 0
        fi

        PYTHON=$(find_python)
        if [ -z "$PYTHON" ]; then
            log_startup_err "No Python 3 interpreter found. Checked /usr/bin/python3(.8/.9/.10/.11), /usr/local/bin/python3, /var/packages/py3k/target/usr/bin/python3, /var/packages/python3/target/usr/bin/python3, and PATH. Install the 'Python 3' package from DSM Package Center."
            exit 1
        fi

        if [ ! -f "$SCHEDULER" ]; then
            log_startup_err "Scheduler script missing: $SCHEDULER"
            exit 1
        fi

        # Sanity-check the interpreter once before we go nohup. If the
        # interpreter can't even start (corrupted install, missing .so),
        # surface the error synchronously instead of letting nohup eat it.
        if ! "$PYTHON" -c "import sys; sys.exit(0)" >> "$STARTUP_ERR" 2>&1; then
            log_startup_err "Python interpreter failed sanity check: $PYTHON"
            exit 1
        fi

        # Kick it off. The scheduler wraps its own imports so top-level
        # ImportError / syntax issues land in startup-error.log instead of
        # silently disappearing.
        SYNOPKG_PKGVAR="$VAR_DIR" \
            ICLOUD_STARTUP_ERR="$STARTUP_ERR" \
            nohup "$PYTHON" "$SCHEDULER" >> "$LOG_FILE" 2>&1 &
        echo $! > "$PID_FILE"
        exit 0
        ;;
    stop)
        if [ -f "$PID_FILE" ]; then
            PID=$(cat "$PID_FILE" 2>/dev/null)
            [ -n "$PID" ] && kill "$PID" 2>/dev/null
            rm -f "$PID_FILE"
        fi
        # Also kill any lingering sync_runner subprocesses (manual syncs
        # detach via start_new_session, so the scheduler PID does not own
        # them). Match on the package target path to avoid touching unrelated
        # python processes.
        pkill -f "$TARGET_DIR/bin/sync_runner.py" 2>/dev/null || true
        pkill -f "$TARGET_DIR/bin/scheduler.py" 2>/dev/null || true
        # Give child downloads a moment to unwind, then hard-kill leftovers.
        sleep 1
        pkill -9 -f "$TARGET_DIR/bin/sync_runner.py" 2>/dev/null || true
        pkill -9 -f "$TARGET_DIR/bin/scheduler.py" 2>/dev/null || true
        exit 0
        ;;
    status)
        if is_running; then exit 0; else exit 3; fi
        ;;
    log)
        echo "$LOG_FILE"
        exit 0
        ;;
esac

exit 1
