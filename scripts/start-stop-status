#!/bin/sh
# Runs as the package user. We cannot write /etc/crontab, so scheduling
# is handled by a long-running Python daemon (bin/scheduler.py).

PKG_DIR="/var/packages/iCloudPhotoSync"
TARGET_DIR="$PKG_DIR/target"
VAR_DIR="$PKG_DIR/var"
SCHEDULER="$TARGET_DIR/bin/scheduler.py"
PYTHON="/usr/bin/python3"
PID_FILE="$VAR_DIR/scheduler.pid"
LOG_FILE="$VAR_DIR/logs/scheduler.log"

mkdir -p "$VAR_DIR/logs" 2>/dev/null || true

is_running() {
    [ -f "$PID_FILE" ] || return 1
    PID=$(cat "$PID_FILE" 2>/dev/null)
    [ -n "$PID" ] || return 1
    kill -0 "$PID" 2>/dev/null
}

case $1 in
    start)
        if is_running; then
            exit 0
        fi
        SYNOPKG_PKGVAR="$VAR_DIR" nohup "$PYTHON" "$SCHEDULER" >> "$LOG_FILE" 2>&1 &
        echo $! > "$PID_FILE"
        exit 0
        ;;
    stop)
        if [ -f "$PID_FILE" ]; then
            PID=$(cat "$PID_FILE" 2>/dev/null)
            [ -n "$PID" ] && kill "$PID" 2>/dev/null
            rm -f "$PID_FILE"
        fi
        # Also kill any lingering sync_runner subprocesses (manual syncs
        # detach via start_new_session, so the scheduler PID does not own
        # them). Match on the package target path to avoid touching unrelated
        # python processes.
        pkill -f "$TARGET_DIR/bin/sync_runner.py" 2>/dev/null || true
        pkill -f "$TARGET_DIR/bin/scheduler.py" 2>/dev/null || true
        # Give child downloads a moment to unwind, then hard-kill leftovers.
        sleep 1
        pkill -9 -f "$TARGET_DIR/bin/sync_runner.py" 2>/dev/null || true
        pkill -9 -f "$TARGET_DIR/bin/scheduler.py" 2>/dev/null || true
        exit 0
        ;;
    status)
        if is_running; then exit 0; else exit 3; fi
        ;;
    log)
        echo "$LOG_FILE"
        exit 0
        ;;
esac

exit 1
